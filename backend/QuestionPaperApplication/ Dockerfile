# Stage 1: Build the application
FROM maven:3.8.5-openjdk-17 AS build
WORKDIR /app

# Since Render's Root Directory is set to backend/QuestionPaperApplication,
# everything is already in the current directory.
COPY . .

# Build the JAR
RUN mvn clean package -DskipTests

# Stage 2: Run the application
FROM openjdk:17-jdk-slim
WORKDIR /app

# Copy the built JAR from the target folder
COPY --from=build /app/target/*.jar app.jar

# Render assigns a port via the PORT environment variable
EXPOSE 8080

# Run the application
ENTRYPOINT ["java", "-Dserver.port=${PORT}", "-jar", "app.jar"]
